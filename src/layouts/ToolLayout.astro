---
import BaseLayout from './BaseLayout.astro'
import BreadcrumbNav from '../components/BreadcrumbNav.astro'

interface BreadcrumbItem {
  label: string
  href?: string
}

interface Props {
  title: string
  description: string
  primaryKeyword?: string
  breadcrumbs?: BreadcrumbItem[]
  schema?: object[]
  ogImage?: string
}

const {
  title,
  description,
  primaryKeyword,
  breadcrumbs = [],
  schema = [],
  ogImage,
} = Astro.props
---

<BaseLayout
  title={title}
  description={description}
  primaryKeyword={primaryKeyword}
  schema={schema}
  ogImage={ogImage}
>
  <div class="max-w-3xl mx-auto px-4 py-10">
    {breadcrumbs.length > 0 && <BreadcrumbNav items={breadcrumbs} />}

    <article class="prose prose-slate prose-lg max-w-none">
      <slot />
    </article>
  </div>
</BaseLayout>
