---
import SEOHead from '../components/SEOHead.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import '../styles/global.css'

interface Props {
  title: string
  description: string
  primaryKeyword?: string
  canonicalUrl?: string
  ogImage?: string
  schema?: object[]
  noindex?: boolean
}

const { title, description, primaryKeyword, canonicalUrl, ogImage, schema, noindex } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead
      title={title}
      description={description}
      primaryKeyword={primaryKeyword}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
      schema={schema}
      noindex={noindex}
    />
  </head>
  <body class="min-h-screen flex flex-col bg-slate-50">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
