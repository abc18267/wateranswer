---
import BaseLayout from './BaseLayout.astro'
import BreadcrumbNav from '../components/BreadcrumbNav.astro'
import FAQSection from '../components/FAQSection.astro'
import SpokeGrid from '../components/SpokeGrid.astro'

interface BreadcrumbItem {
  label: string
  href?: string
}

interface SpokeCard {
  title: string
  href: string
  description: string
  badge?: string
}

interface FAQItem {
  question: string
  answer: string
}

interface Props {
  title: string
  description: string
  primaryKeyword?: string
  breadcrumbs?: BreadcrumbItem[]
  spokeCards?: SpokeCard[]
  spokeHeading?: string
  faq?: FAQItem[]
  schema?: object[]
  ogImage?: string
}

const {
  title,
  description,
  primaryKeyword,
  breadcrumbs = [],
  spokeCards = [],
  spokeHeading,
  faq = [],
  schema = [],
  ogImage,
} = Astro.props
---

<BaseLayout
  title={title}
  description={description}
  primaryKeyword={primaryKeyword}
  schema={schema}
  ogImage={ogImage}
>
  <div class="max-w-4xl mx-auto px-4 py-10">
    {breadcrumbs.length > 0 && <BreadcrumbNav items={breadcrumbs} />}

    <article class="prose prose-slate prose-lg max-w-none">
      <slot />
    </article>

    {spokeCards.length > 0 && (
      <div class="mt-12 not-prose">
        <SpokeGrid cards={spokeCards} heading={spokeHeading} />
      </div>
    )}

    {faq.length > 0 && (
      <div class="not-prose">
        <FAQSection items={faq} />
      </div>
    )}
  </div>
</BaseLayout>
