---
import BaseLayout from './BaseLayout.astro'
import BreadcrumbNav from '../components/BreadcrumbNav.astro'
import FAQSection from '../components/FAQSection.astro'
import SpokeGrid from '../components/SpokeGrid.astro'

interface BreadcrumbItem {
  label: string
  href?: string
}

interface SpokeCard {
  title: string
  href: string
  description: string
  badge?: string
}

interface FAQItem {
  question: string
  answer: string
}

interface Props {
  title: string
  description: string
  primaryKeyword?: string
  breadcrumbs?: BreadcrumbItem[]
  spokeCards?: SpokeCard[]
  spokeHeading?: string
  faq?: FAQItem[]
  schema?: object[]
  ogImage?: string
  showDisclaimer?: boolean
}

const {
  title,
  description,
  primaryKeyword,
  breadcrumbs = [],
  spokeCards = [],
  spokeHeading,
  faq = [],
  schema = [],
  ogImage,
  showDisclaimer = true,
} = Astro.props
---

<BaseLayout
  title={title}
  description={description}
  primaryKeyword={primaryKeyword}
  schema={schema}
  ogImage={ogImage}
>
  <div class="max-w-4xl mx-auto px-4 py-10">
    {breadcrumbs.length > 0 && <BreadcrumbNav items={breadcrumbs} />}

    {showDisclaimer && (
      <div class="bg-blue-50 border border-blue-200 rounded-lg px-4 py-3 mb-6 text-sm text-blue-900">
        <strong>Health information notice:</strong> This page covers potential health effects
        associated with water contaminants. It's general information, not medical advice.
        Ask your doctor about risks specific to your health history.
      </div>
    )}

    <article class="prose prose-slate prose-lg max-w-none">
      <slot />
    </article>

    {spokeCards.length > 0 && (
      <div class="mt-12 not-prose">
        <SpokeGrid cards={spokeCards} heading={spokeHeading} />
      </div>
    )}

    {faq.length > 0 && (
      <div class="not-prose">
        <FAQSection items={faq} />
      </div>
    )}

    {showDisclaimer && (
      <div class="not-prose mt-10 bg-blue-50 border border-blue-200 rounded-lg px-4 py-3 text-sm text-blue-900">
        <strong>Medical disclaimer:</strong> WaterAnswer.com provides general information only.
        Nothing here is medical advice. Consult a licensed healthcare provider before making
        decisions about your health.
      </div>
    )}
  </div>
</BaseLayout>
