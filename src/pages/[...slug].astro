---
/**
 * Dynamic routing for all content collection pages.
 * Each MDX file maps to its folder path as the URL slug.
 */
import { getCollection } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

import HubLayout from '../layouts/HubLayout.astro'
import SpokeLayout from '../layouts/SpokeLayout.astro'
import ReviewLayout from '../layouts/ReviewLayout.astro'
import ContaminantLayout from '../layouts/ContaminantLayout.astro'
import HowToLayout from '../layouts/HowToLayout.astro'
import ToolLayout from '../layouts/ToolLayout.astro'

export async function getStaticPaths() {
  const collections = ['your-water', 'testing', 'treatment', 'tools', 'learn'] as const

  const allEntries = (
    await Promise.all(
      collections.map((col) => getCollection(col as Parameters<typeof getCollection>[0]))
    )
  ).flat()

  return allEntries.map((entry) => {
    // Build slug from collection + id
    // entry.id may include file extension (.mdx) in Astro v5
    // e.g. collection "your-water", id "index.mdx" → slug "your-water"
    //      collection "your-water", id "contaminants/pfas/index.mdx" → slug "your-water/contaminants/pfas"
    const cleanId = entry.id
      .replace(/\.(mdx?|md)$/, '')   // strip extension
      .replace(/(\/index|^index)$/, '') // strip trailing /index
    const parts = [entry.collection, ...cleanId.split('/').filter(Boolean)]
    const slug = parts.join('/')
    return { params: { slug }, props: { entry } }
  })
}

type AnyEntry = CollectionEntry<'your-water'> | CollectionEntry<'testing'> | CollectionEntry<'treatment'> | CollectionEntry<'tools'> | CollectionEntry<'learn'>

interface Props {
  entry: AnyEntry
}

const { entry } = Astro.props
const { Content } = await entry.render()
const data = entry.data

// Build breadcrumbs from slug parts
const slug = Astro.params.slug || ''
const slugParts = slug.split('/').filter(Boolean)
const breadcrumbs = slugParts.slice(0, -1).map((part, i) => ({
  label: part.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
  href: '/' + slugParts.slice(0, i + 1).join('/'),
}))

const layoutProps = {
  title: data.title,
  description: data.description,
  primaryKeyword: data.primaryKeyword,
  breadcrumbs,
  faq: data.faq,
  schema: [],
  ogImage: data.heroImage,
  updatedDate: data.updatedDate,
}
---

{data.pageType === 'hub' && (
  <HubLayout {...layoutProps}>
    <Content />
  </HubLayout>
)}
{data.pageType === 'spoke' && (
  <SpokeLayout {...layoutProps}>
    <Content />
  </SpokeLayout>
)}
{data.pageType === 'review' && (
  <ReviewLayout {...layoutProps}>
    <Content />
  </ReviewLayout>
)}
{data.pageType === 'contaminant' && (
  <ContaminantLayout {...layoutProps} showDisclaimer={true}>
    <Content />
  </ContaminantLayout>
)}
{data.pageType === 'howto' && (
  <HowToLayout {...layoutProps} affiliateDisclosure={data.affiliateDisclosure}>
    <Content />
  </HowToLayout>
)}
{data.pageType === 'tool' && (
  <ToolLayout {...layoutProps}>
    <Content />
  </ToolLayout>
)}
{data.pageType === 'learn' && (
  <SpokeLayout {...layoutProps}>
    <Content />
  </SpokeLayout>
)}
