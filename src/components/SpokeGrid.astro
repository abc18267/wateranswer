---
interface SpokeCard {
  title: string
  href: string
  description: string
  badge?: string
}

interface Props {
  cards: SpokeCard[]
  heading?: string
}

const { cards, heading } = Astro.props
---

{heading && <h2 class="text-2xl font-bold text-slate-900 mb-6">{heading}</h2>}
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
  {cards.map((card) => (
    <a
      href={card.href}
      class="group block rounded-xl border border-slate-200 p-5 hover:border-cyan-300 hover:shadow-md transition-all no-underline bg-white"
    >
      {card.badge && (
        <span class="inline-block text-xs font-semibold text-cyan-700 bg-cyan-50 border border-cyan-200 rounded-full px-2 py-0.5 mb-2">
          {card.badge}
        </span>
      )}
      <p class="font-semibold text-slate-900 group-hover:text-cyan-700 mb-1">{card.title}</p>
      <p class="text-sm text-slate-500 leading-snug">{card.description}</p>
    </a>
  ))}
</div>
